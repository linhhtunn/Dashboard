PORT=7860
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
LOG_LEVEL=INFO

# Local Docker smoke test should use in-memory memory by default.
# Use supabase only when SUPABASE_DB_URL or MEMORY_POSTGRES_DSN is set.
MEMORY_CHECKPOINTER=memory
MEMORY_STORE=memory
MEMORY_POSTGRES_DSN=
SUPABASE_DB_URL=

INTENT_CLASSIFIER_USE_LLM=true

LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_CAPTURE_CONTENT=false
LANGFUSE_PATIENT_ID_MODE=hash
LANGFUSE_HASH_SALT=

MEMORY_COMPACT_TURN_THRESHOLD=6
MEMORY_OVERLAP_TURNS=2
SQLITE_DB_PATH=
