# Local config for the wearable simulator generate-and-replay Docker job.
# Copy this file to backend/simulator/pipeline/jobs/.env and edit values locally.
# Do not commit .env.

PATIENT_IDS=P005
START_TIME=2026-06-03T05:00:00Z
DURATION_HOURS=1

STREAMS=wearable_continuous wearable_steps_event wearable_stress wearable_ppi_batch wearable_motion_batch wearable_bp_triggered wearable_spo2_triggered wearable_ecg_triggered wearable_battery sleep_timeline daily_metrics
REPLAY_MODE=interleaved
REPLAY_DELAY_SECONDS=0

DRY_RUN=true
NO_DECLARE=false
PUBLISH_LIMIT=5
PUBLISH_SKIP=0
STRICT_STREAM_FILES=false

# Required only when DRY_RUN=false.
RABBITMQ_URL=
