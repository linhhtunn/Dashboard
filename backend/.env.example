
DATABASE_URL=
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-publishable-or-anon-key
SUPABASE_SECRET_KEY=your-secret-key
RABBITMQ_URL=amqps://USER:PASSWORD@HOST/VHOST
RABBITMQ_EXCHANGE=health.events
RABBITMQ_DLX_EXCHANGE=health.dlx
RABBITMQ_RAW_QUEUE=q.team2.wearable_continuous
RABBITMQ_ROUTING_KEY=wearable.continuous
# Other wearable v2 queues (run separate consumers if needed):
# q.team2.wearable_spo2_triggered / wearable.spo2_triggered
# q.team2.wearable_ecg_triggered / wearable.ecg_triggered
# q.team2.sleep_timeline / wearable.sleep_timeline
# q.team2.daily_metrics / wearable.daily_metrics
RABBITMQ_GROUND_TRUTH_QUEUE=q.team3.ground_truth
RABBITMQ_GROUND_TRUTH_ROUTING_KEY=scenario.ground_truth
RABBITMQ_DEAD_LETTER_QUEUE=q.dead_letter
RABBITMQ_DEAD_LETTER_ROUTING_KEY=dead

# Ingestion — optional overrides (defaults aligned with rabbit_mq/topology_config.py)
# INGESTION_PREFETCH_COUNT=100
# INGESTION_DB_BATCH_COMMIT_SIZE=25
# INGESTION_LOG_EVERY_N_MESSAGES=50
# INGESTION_HEARTBEAT_SECONDS=30
# INGESTION_RABBITMQ_PASSIVE_CONSUME=true
# INGESTION_REQUEUE_ON_ERROR=false
# INGESTION_REQUIRED_TABLES=patients,raw_vitals,clean_vitals
# INGESTION_DEFAULT_FIXTURE_PATH=tests/fixtures/sample_messages.json
# INGESTION_MOCK_PATIENT_ID=P001
