# Copy to backend/observability/.env and adjust for your cloud resources.
# This file stores paths, ports, dashboard URLs, database URLs, and repeatable evaluation profiles.
# Do not commit the real .env file.

# Workspace paths
WORKSPACE_ROOT=C:/Users/ADMIN/software-engineering
BACKEND_DIR=C:/Users/ADMIN/software-engineering/backend
SIMULATOR_OUTPUT_DIR=C:/Users/ADMIN/software-engineering/backend/simulator/output
OBSERVABILITY_DIR=C:/Users/ADMIN/software-engineering/backend/observability
OBSERVABILITY_REPORT_DIR=C:/Users/ADMIN/software-engineering/backend/observability/reports

# Local monitoring endpoints
OBSERVABILITY_PROMETHEUS_PORT=9108
APP_METRICS_URL=http://localhost:9108/metrics
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Grafana Cloud.
# Fill these if you want local Prometheus to remote_write metrics to Grafana Cloud.
GRAFANA_CLOUD_URL=
GRAFANA_CLOUD_PROMETHEUS_REMOTE_WRITE_URL=
GRAFANA_CLOUD_PROMETHEUS_USERNAME=
GRAFANA_CLOUD_PROMETHEUS_PASSWORD=
# Local-only: ./prometheus/prometheus.yml
# Grafana Cloud remote_write: ./prometheus/prometheus.cloud.yml
PROMETHEUS_CONFIG_FILE=./prometheus/prometheus.yml

# Grafana Alloy alternative to local Prometheus.
# These names match Grafana Cloud's Windows Alloy onboarding script.
GCLOUD_RW_API_KEY=
GCLOUD_HOSTED_METRICS_ID=
GCLOUD_HOSTED_METRICS_URL=
GCLOUD_HOSTED_LOGS_ID=
GCLOUD_HOSTED_LOGS_URL=
GCLOUD_FM_URL=
GCLOUD_FM_HOSTED_ID=
GCLOUD_FM_POLL_FREQUENCY=60s

# Supabase / app database used by backend code.
# Fill these with your real cloud Supabase values.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# TigerData / TimescaleDB used by backend code.
# Fill TIMESCALE_DB_URL with your TigerData/Timescale cloud connection string.
TIMESCALE_DB_URL=
TIMESCALE_DB_PASSWORD=
TIMESCALE_MIN_CONNECTIONS=1
TIMESCALE_MAX_CONNECTIONS=5
TIMESCALE_BATCH_SIZE=500

# RabbitMQ / CloudAMQP used by Team 1 publisher and Team 2+3 consumer.
RABBITMQ_URL=

# Optional infrastructure Prometheus endpoints.
# RabbitMQ exposes this when the rabbitmq_prometheus plugin is enabled.
RABBITMQ_PROMETHEUS_TARGET=host.docker.internal:15692
NODE_EXPORTER_TARGET=host.docker.internal:9100
CADVISOR_TARGET=host.docker.internal:8080

# RabbitMQ contract
RABBITMQ_EVENTS_EXCHANGE=health.events
RABBITMQ_ALERT_ROUTING_KEY=alerts.created
RABBITMQ_ALERT_QUEUE=q.alerts.created

# Database contract
# Grafana cannot reliably consume the full DB URL from the Python app env.
# Split your cloud connection strings into these fields for Grafana datasources.
# Example TigerData host: xxxxx.aws.tigerdata.com
TIMESCALE_HOST=
TIMESCALE_PORT=5432
TIMESCALE_DB=
TIMESCALE_USER=
TIMESCALE_PASSWORD=
TIMESCALE_SSLMODE=require
# Example Supabase host: db.<project-ref>.supabase.co
SUPABASE_HOST=
SUPABASE_PORT=5432
SUPABASE_DB=postgres
SUPABASE_USER=postgres
SUPABASE_PASSWORD=
SUPABASE_SSLMODE=require
TIMESCALE_TRACE_TABLE=perf_trace_events
TIMESCALE_QUEUE_TABLE=perf_queue_samples
TIMESCALE_RUN_TABLE=test_runs
TIMESCALE_RESULTS_TABLE=evaluation_results
SUPABASE_ALERTS_TABLE=public.alerts
SUPABASE_ALERT_CONTEXT_TABLE=public.alert_context

# Grafana dashboard files
GRAFANA_DASHBOARD_A_FUNCTIONAL=C:/Users/ADMIN/software-engineering/backend/observability/grafana/dashboards/dashboard_a_functional_health.json
GRAFANA_DASHBOARD_B_PERFORMANCE=C:/Users/ADMIN/software-engineering/backend/observability/grafana/dashboards/dashboard_b_performance.json
GRAFANA_DASHBOARD_C_TEAM4=C:/Users/ADMIN/software-engineering/backend/observability/grafana/dashboards/dashboard_c_team4_realtime.json

# Default evaluation parameters
EVAL_RUN_ID=manual_local
EVAL_PROFILE=smoke
EVAL_PATIENT_ID=P005
EVAL_STREAMS=wearable_continuous wearable_spo2_triggered wearable_ppi_batch wearable_motion_batch
EVAL_LIMIT=120
EVAL_TARGET_MSG_SEC=5
EVAL_DURATION_SECONDS=0
EVAL_TEAM4_PATH=rabbitmq

# Load ladder profiles
LOAD_LEVEL_1_RUN_ID=load_1p_2m
LOAD_LEVEL_1_PATIENTS=1
LOAD_LEVEL_1_DURATION_MINUTES=2
LOAD_LEVEL_1_TARGET_MSG_SEC=5

LOAD_LEVEL_2_RUN_ID=load_10p_10m
LOAD_LEVEL_2_PATIENTS=10
LOAD_LEVEL_2_DURATION_MINUTES=10
LOAD_LEVEL_2_TARGET_MSG_SEC=50

LOAD_LEVEL_3_RUN_ID=load_50p_30m
LOAD_LEVEL_3_PATIENTS=50
LOAD_LEVEL_3_DURATION_MINUTES=30
LOAD_LEVEL_3_TARGET_MSG_SEC=250

LOAD_LEVEL_4_RUN_ID=load_100p_60m
LOAD_LEVEL_4_PATIENTS=100
LOAD_LEVEL_4_DURATION_MINUTES=60
LOAD_LEVEL_4_TARGET_MSG_SEC=500

LOAD_LEVEL_5_RUN_ID=load_motion_ppi_heavy
LOAD_LEVEL_5_STREAMS=wearable_ppi_batch wearable_motion_batch wearable_spo2_triggered
LOAD_LEVEL_5_TARGET_MSG_SEC=500
