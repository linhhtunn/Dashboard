# Runtime safety controls
CARESIGNAL_ENVIRONMENT=development
ALLOW_DEMO_MODE=true
AI_MODE=off
ALERT_DISPATCH_MODE=shadow
PHI_PROCESSING_APPROVED=false
APP_BASE_URL=http://localhost:3000

# AI Agent (Cloud Run for production; Hugging Face Spaces is forbidden)
AI_AGENT_BASE_URL=http://127.0.0.1:8005
AI_AGENT_CHAT_PATH=/api/agent/chat

# Supabase Auth / workflow database
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=server-only-service-role-key
SUPABASE_DATABASE_URL=postgresql://postgres.[ref]:PASSWORD@host:6543/postgres?sslmode=require

# Timescale Cloud
TIMESCALE_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/tsdb?sslmode=require

# Alert escalation (server-only)
ALERT_DISPATCH_SECRET=replace-with-random-secret
CRON_SECRET=replace-with-vercel-cron-secret
HOSPITAL_ALERT_WEBHOOK_URL=https://hospital.example/caresignal/alerts
HOSPITAL_ALERT_WEBHOOK_SECRET=replace-with-shared-signing-secret

# Optional browser-side clinical API override. Empty means same-origin /api/*.
# NEXT_PUBLIC_CLINICAL_API_BASE=

# Realtime simulator service used by /metrics (local default: http://127.0.0.1:8021)
SIMULATOR_API_BASE=http://127.0.0.1:8021
